# Copy to .env.screenshots (gitignored) for Playwright marketing captures.
# Used by app/playwright.config.ts and scripts/capture-marketing-screenshots.mjs

MARQQ_SCREENSHOT_EMAIL=you@company.com
MARQQ_SCREENSHOT_PASSWORD=your-password

# Optional — defaults to Vite dev server
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3007
